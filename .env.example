# =============================================================
#  .env.example — Tool-36 Incident Evidence Locker
#
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in real values in .env
#    3. NEVER commit .env — it is in .gitignore
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tool36db
DB_USERNAME=postgres
DB_PASSWORD=your_strong_postgres_password_here

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_char_random_string_minimum
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Email (SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here

# ── AI Service ────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:5000

# ── Groq API (AI Developer sets this) ────────────────────────
GROQ_API_KEY=your_groq_api_key_from_console.groq.com
